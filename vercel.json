{
    "version": 2,
    "public": true,
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "https://aranya-backend-x0qy.onrender.com/api/$1"
        },
        {
            "source": "/uploads/(.*)",
            "destination": "https://aranya-backend-x0qy.onrender.com/uploads/$1"
        },
        {
            "source": "/(.*)",
            "destination": "src/client/dist/$1"
        },
        {
            "source": "/(.*)",
            "destination": "src/client/dist/index.html"
        }
    ]
}